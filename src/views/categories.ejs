<%- include('partials/header') %>

<section class="py-16">
    <div class="max-container">
        <header class="mb-16">
            <h1 class="text-4xl font-bold mb-4"><%= title %></h1>
            <p class="text-slate-600">Find the right cause for your passions and skills.</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% categories.forEach(cat => { %>
            <div class="relative h-80 rounded-card overflow-hidden group cursor-pointer transition-all card-hover">
                <img src="<%= cat.image_url %>" alt="<%= cat.name %>" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-125">
                <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent"></div>
                
                <div class="absolute inset-0 p-8 flex flex-col justify-end">
                    <div class="w-12 h-12 bg-white/20 backdrop-blur-md rounded-xl flex items-center justify-center text-white mb-4 group-hover:bg-secondary transition-colors duration-300">
                        <i data-lucide="<%= cat.icon %>" class="w-6 h-6"></i>
                    </div>
                    <h2 class="text-2xl font-bold text-white mb-2"><%= cat.name %></h2>
                    <a href="/projects?category=<%= cat.name.toLowerCase() %>" class="flex items-center gap-2 text-secondary font-bold text-sm group-hover:text-white transition-colors">
                        Browse <%= cat.name %> <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </a>
                </div>
            </div>
            <% }); %>
        </div>

        <!-- Contact Footer Card -->
        <div class="mt-20 bg-surface-container border border-outline rounded-[32px] p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8 transition-all card-hover">
            <div class="text-center md:text-left">
                <h2 class="text-2xl font-bold mb-2">Can't find what you're looking for?</h2>
                <p class="text-slate-600">Our team is here to help you find the perfect match for your skills.</p>
            </div>
            <div class="flex flex-wrap justify-center gap-4">
                <button class="px-8 py-4 bg-primary text-white font-bold rounded-xl hover:bg-secondary transition-all">
                    Contact Us
                </button>
                <button class="px-8 py-4 border-2 border-primary text-primary font-bold rounded-xl hover:bg-primary hover:text-white transition-all">
                    Suggest a Category
                </button>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
