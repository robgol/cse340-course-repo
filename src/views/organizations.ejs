<%- include('partials/header') %>

<section class="py-16">
    <div class="max-container">
        <header class="text-center mb-16">
            <h1 class="text-4xl font-bold mb-4"><%= title %></h1>
            <div class="w-20 h-1 bg-secondary mx-auto"></div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
            <!-- Grid of Organizations -->
            <div class="lg:col-span-3">
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                    <% 
                    const orgs = [
                        { name: 'BrightFuture Builders', logo: 'brightfuture-logo.png', desc: 'Working to build a better future through community infrastructure and housing projects.', email: 'info@brightfuture.org' },
                        { name: 'GreenHarvest Growers', logo: 'greenharvest-logo.png', desc: 'Promoting sustainable agriculture and providing fresh produce to those in need.', email: 'contact@greenharvest.org' },
                        { name: 'UnityServe Volunteers', logo: 'unityserve-logo.png', desc: 'Bringing people together to serve their local communities through diverse volunteer initiatives.', email: 'hello@unityserve.org' }
                    ];
                    %>

                    <% orgs.forEach(org => { %>
                    <div class="bg-surface-container border border-outline rounded-card p-6 flex flex-col items-center text-center transition-all card-hover">
                        <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mb-4 border border-outline overflow-hidden p-2">
                            <img src="/images/<%= org.logo %>" alt="<%= org.name %> logo" class="w-full h-full object-contain">
                        </div>
                        <h3 class="text-xl font-bold mb-3"><%= org.name %></h3>
                        <p class="text-slate-600 text-sm mb-6 flex-grow"><%= org.desc %></p>
                        <a href="mailto:<%= org.email %>" class="w-full py-3 px-4 bg-primary text-white text-sm font-bold rounded-lg hover:bg-secondary transition-colors">
                            Contact Organization
                        </a>
                    </div>
                    <% }); %>
                </div>
            </div>

            <!-- Impact Sidebar -->
            <aside class="space-y-6">
                <div class="bg-primary text-white p-8 rounded-card shadow-xl sticky top-28">
                    <h3 class="text-2xl font-bold mb-6">Impact Statistics</h3>
                    <div class="space-y-6">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-white/10 rounded-lg flex items-center justify-center">
                                <i data-lucide="globe" class="text-secondary w-6 h-6"></i>
                            </div>
                            <div>
                                <div class="text-xl font-bold">45+</div>
                                <div class="text-slate-400 text-sm">Countries reached</div>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-white/10 rounded-lg flex items-center justify-center">
                                <i data-lucide="handshake" class="text-secondary w-6 h-6"></i>
                            </div>
                            <div>
                                <div class="text-xl font-bold">120+</div>
                                <div class="text-slate-400 text-sm">Partnerships</div>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-white/10 rounded-lg flex items-center justify-center">
                                <i data-lucide="smile" class="text-secondary w-6 h-6"></i>
                            </div>
                            <div>
                                <div class="text-xl font-bold">10k+</div>
                                <div class="text-slate-400 text-sm">Lives Impacted</div>
                            </div>
                        </div>
                    </div>
                    <button class="w-full mt-10 py-4 px-6 bg-secondary text-white font-bold rounded-xl hover:bg-white hover:text-secondary transition-all card-hover">
                        Become a Partner
                    </button>
                </div>
            </aside>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
