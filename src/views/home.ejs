<%- include('partials/header') %>

<!-- Hero Section -->
<section class="py-20 overflow-hidden">
    <div class="max-container grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-8">
            <h1 class="text-5xl lg:text-7xl font-extrabold leading-tight">
                Welcome to the <span class="text-secondary">CSE 340</span> Service Network!
            </h1>
            <p class="text-xl text-slate-600 max-w-lg">
                Connecting talented individuals with meaningful service opportunities. Join our network today and make a real difference in your community.
            </p>
            <div class="flex flex-wrap gap-4">
                <a href="/projects" class="px-8 py-4 bg-secondary text-white font-bold rounded-full hover:bg-opacity-90 transition-all card-hover flex items-center gap-2">
                    Explore Opportunities <i data-lucide="arrow-right" class="w-5 h-5"></i>
                </a>
                <a href="/organizations" class="px-8 py-4 border-2 border-primary text-primary font-bold rounded-full hover:bg-primary hover:text-white transition-all card-hover">
                    Register Organization
                </a>
            </div>
        </div>
        <div class="relative">
            <div class="absolute -top-20 -right-20 w-64 h-64 bg-accent/20 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-secondary/20 rounded-full blur-3xl"></div>
            <div class="bg-white p-4 rounded-3xl shadow-2xl relative z-10">
                <img src="/images/cse340-service-network.png" alt="Community Service Illustration" class="rounded-2xl w-full h-[500px] object-cover">
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-24 bg-white">
    <div class="max-container text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">How We Serve</h2>
        <div class="w-24 h-1 bg-secondary mx-auto"></div>
    </div>
    <div class="max-container grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-8 rounded-card border border-outline hover:border-secondary transition-all card-hover group">
            <div class="w-16 h-16 bg-surface rounded-2xl flex items-center justify-center text-secondary mb-6 group-hover:bg-secondary group-hover:text-white transition-colors">
                <i data-lucide="users" class="w-8 h-8"></i>
            </div>
            <h3 class="text-2xl font-bold mb-4">Connect with Organizations</h3>
            <p class="text-slate-600">Browse through our curated list of partner organizations looking for passionate volunteers.</p>
        </div>
        <div class="p-8 rounded-card border border-outline hover:border-secondary transition-all card-hover group">
            <div class="w-16 h-16 bg-surface rounded-2xl flex items-center justify-center text-secondary mb-6 group-hover:bg-secondary group-hover:text-white transition-colors">
                <i data-lucide="line-chart" class="w-8 h-8"></i>
            </div>
            <h3 class="text-2xl font-bold mb-4">Track Progress</h3>
            <p class="text-slate-600">Keep track of your volunteer applications and active projects all in one place.</p>
        </div>
        <div class="p-8 rounded-card border border-outline hover:border-secondary transition-all card-hover group">
            <div class="w-16 h-16 bg-surface rounded-2xl flex items-center justify-center text-secondary mb-6 group-hover:bg-secondary group-hover:text-white transition-colors">
                <i data-lucide="award" class="w-8 h-8"></i>
            </div>
            <h3 class="text-2xl font-bold mb-4">Certified Hours</h3>
            <p class="text-slate-600">Get certified certificates for your completed service hours to boost your professional profile.</p>
        </div>
    </div>
</section>

<!-- CTA Banner Section -->
<section class="py-24 max-container px-6">
    <div class="bg-primary rounded-[40px] p-12 lg:p-20 text-center relative overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-secondary/10 rounded-full -mr-48 -mt-48 blur-3xl"></div>
        <div class="relative z-10 max-w-3xl mx-auto space-y-10">
            <h2 class="text-4xl lg:text-5xl font-bold text-white leading-tight">Ready to make an impact? Join our community today.</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
                <div>
                    <div class="text-4xl font-extrabold text-secondary mb-2">150+</div>
                    <div class="text-slate-400 font-medium">Organizations</div>
                </div>
                <div>
                    <div class="text-4xl font-extrabold text-secondary mb-2">500+</div>
                    <div class="text-slate-400 font-medium">Projects</div>
                </div>
                <div>
                    <div class="text-4xl font-extrabold text-secondary mb-2">12k</div>
                    <div class="text-slate-400 font-medium">Volunteers</div>
                </div>
                <div>
                    <div class="text-4xl font-extrabold text-secondary mb-2">24/7</div>
                    <div class="text-slate-400 font-medium">Support</div>
                </div>
            </div>
            <button class="px-12 py-5 bg-white text-primary font-bold rounded-full hover:bg-secondary hover:text-white transition-all card-hover">
                Get Started Today
            </button>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
